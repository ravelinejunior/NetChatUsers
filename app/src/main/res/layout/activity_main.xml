<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00695C"
    android:theme="@android:style/Theme.NoTitleBar">

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/vp_novo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#004D40"
        app:layout_constraintBottom_toTopOf="@+id/sld_tab"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_weight="1"></androidx.viewpager.widget.ViewPager>

    <br.com.ravelineNetUsers.Activities.helper.SlidingTabLayout
        android:id="@+id/sld_tab"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="731dp"
        android:background="@color/colorPrimaryDark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/vp_novo">

    </br.com.ravelineNetUsers.Activities.helper.SlidingTabLayout>


</androidx.constraintlayout.widget.ConstraintLayout>